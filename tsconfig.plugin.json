{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./build",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "plugin/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "build"
  ]
}
