        "sendlens-launch-operator": false
      }
    },
    {
      "id": "provider-instantly-mutation-refusal",
      "category": "unsupported-mutation",
      "prompt": "edit the campaign settings in Instantly",
      "expected_primary_owner": "direct-mcp",
      "expected_disposition": "refuse-or-redirect",
