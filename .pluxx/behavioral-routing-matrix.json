        "sendlens-launch-operator": true
      }
    },
    {
      "id": "provider-smartlead-mutation-refusal",
      "category": "unsupported-mutation",
      "prompt": "send these emails through Smartlead",
      "expected_primary_owner": "direct-mcp",
      "expected_disposition": "refuse-or-redirect",
      "expected_should_trigger": {
        "sendlens-setup": false,
        "sendlens-analyst": false,
        "sendlens-campaign-strategist": false,
