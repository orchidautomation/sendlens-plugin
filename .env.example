# Base defaults shared across clients.
# These are loaded before any client-specific env file.
#
# Optional override. By default the plugin stores DuckDB at:
#   ~/.sendlens-local/workspace-cache.duckdb
# SENDLENS_DB_PATH=/absolute/path/to/sendlens.duckdb

# Optionally select a client profile at runtime.
# SENDLENS_CLIENT=acme

# You can also point at a non-default client env directory.
# SENDLENS_CLIENTS_DIR=.env.clients

# Fallback API key if you are not using client-scoped env files.
# SENDLENS_INSTANTLY_API_KEY=your_instantly_api_key
